# Copy this to .env and fill in real values before deploying.
# Never commit the actual .env file.

PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string
# Create a cluster at https://cloud.mongodb.com
# Whitelist your server IP in Network Access
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/proximity?retryWrites=true&w=majority

# Redis Cloud or Upstash connection string
# https://app.redislabs.com or https://upstash.com
REDIS_URL=redis://default:<password>@<host>:<port>

# JWT secrets — generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_hex_string
JWT_REFRESH_SECRET=replace_with_different_64_byte_hex_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Your production frontend domain (no trailing slash)
CLIENT_URL=https://yourdomain.com